rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function clientMembershipTypeIsAllowed() {
      return request.resource.data.membershipType in ["free", "trial"] &&
        request.resource.data.membershipStatus in ["free", "trial"];
    }

    function isAiRequestUsageUpdate() {
      return resource.data.membershipStatus == "active" &&
        request.resource.data.membershipStatus == resource.data.membershipStatus &&
        request.resource.data.membershipType == resource.data.membershipType &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["aiRequestsUsed", "aiResetDate", "lastRequestTimestamp", "updatedAt"]);
    }

    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId);

      match /profile/{profileId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /programs/{programId} {
        allow read, create, update, delete: if isOwner(userId);

        match /days/{dayId} {
          allow read, create, update, delete: if isOwner(userId);
        }
      }

      match /workoutSessions/{sessionId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /activeWorkout/{activeWorkoutId} {
        allow read, create, update, delete: if
          isOwner(userId) &&
          activeWorkoutId == "current";
      }

      match /bodyMeasurements/{measurementId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /settings/{settingsId} {
        allow read, create, update, delete: if
          isOwner(userId) &&
          settingsId == "main";
      }

      match /membership/{membershipId} {
        allow read: if
          isOwner(userId) &&
          membershipId == "main";
        allow create: if
          isOwner(userId) &&
          membershipId == "main" &&
          clientMembershipTypeIsAllowed();
        allow update: if
          isOwner(userId) &&
          membershipId == "main" &&
          (clientMembershipTypeIsAllowed() || isAiRequestUsageUpdate());
        allow delete: if
          isOwner(userId) &&
          membershipId == "main";
      }

      match /checkoutSessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      match /statistics/{statisticId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // Aktiv app-path. "trash" beholdes som fremtidigt alias.
      match /deletedPrograms/{itemId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /trash/{itemId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /customExercises/{exerciseId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // Aktiv app-path. "aiHistory" beholdes som fremtidigt alias.
      match /aiCopilotHistory/{eventId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /aiHistory/{eventId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /appState/{stateId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /imports/{importId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /records/{recordId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /workouts/{workoutId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /history/{historyId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /measurements/{measurementId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    // Medlemskab og AI-grænser er klientdata i demoen. Reglerne ovenfor
    // beskytter kun ejerskab; de er ikke produktionssikker adgangskontrol.
    // Senere backend/Cloud Functions skal skrive serverbeskyttede felter
    // eller custom claims, som klienten ikke selv kan ændre.

    // Offentlig, ikke-personlig priskonfiguration. Dokumentet opdateres kun
    // af en betroet backend/Cloud Function via Admin SDK.
    match /appConfig/{configId} {
      allow read: if configId == "pricing";
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
