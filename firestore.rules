rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPermanentAdminEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.lower() == "mikehenriksen85@gmail.com";
    }

    function clientUserRootWriteIsAllowed(userId) {
      return isOwner(userId) &&
        request.resource.data.uid == userId &&
        request.resource.data.email == request.auth.token.email &&
        (
          (
            isPermanentAdminEmail() &&
            request.resource.data.role == "admin" &&
            request.resource.data.membership == "lifetime" &&
            request.resource.data.aiRequests == -1
          ) ||
          (
            !isPermanentAdminEmail() &&
            !request.resource.data.keys().hasAny(["role", "aiRequests"]) &&
            !(request.resource.data.membership == "lifetime")
          )
        );
    }

    function clientMembershipTypeIsAllowed() {
      return request.resource.data.membershipType in ["free", "trial"] &&
        request.resource.data.membershipStatus in ["free", "trial"];
    }

    function clientAdminMembershipIsAllowed() {
      return isPermanentAdminEmail() &&
        request.resource.data.role == "admin" &&
        request.resource.data.membership == "lifetime" &&
        request.resource.data.membershipStatus == "active" &&
        request.resource.data.isPremium == true &&
        request.resource.data.aiRequestLimit == -1 &&
        request.resource.data.aiRequests == -1;
    }

    function isAiRequestUsageUpdate() {
      return resource.data.membershipStatus == "active" &&
        request.resource.data.membershipStatus == resource.data.membershipStatus &&
        request.resource.data.membershipType == resource.data.membershipType &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "aiRequestLimit",
            "aiRequestsUsed",
            "aiResetDate",
            "lastRequestTimestamp",
            "updatedAt",
            "firestoreUpdatedAt"
          ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if clientUserRootWriteIsAllowed(userId);
      allow delete: if isOwner(userId);

      match /profile/{profileId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /programs/{programId} {
        allow read, create, update, delete: if isOwner(userId);

        match /days/{dayId} {
          allow read, create, update, delete: if isOwner(userId);
        }
      }

      match /workoutSessions/{sessionId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /activeWorkout/{activeWorkoutId} {
        allow read, create, update, delete: if
          isOwner(userId) &&
          activeWorkoutId == "current";
      }

      match /bodyMeasurements/{measurementId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /settings/{settingsId} {
        allow read, create, update, delete: if
          isOwner(userId) &&
          settingsId == "main";
      }

      match /membership/{membershipId} {
        allow read: if
          isOwner(userId) &&
          membershipId == "main";
        allow create: if
          isOwner(userId) &&
          membershipId == "main" &&
          (clientMembershipTypeIsAllowed() || clientAdminMembershipIsAllowed());
        allow update: if
          isOwner(userId) &&
          membershipId == "main" &&
          (clientMembershipTypeIsAllowed() || clientAdminMembershipIsAllowed() || isAiRequestUsageUpdate());
        allow delete: if
          isOwner(userId) &&
          membershipId == "main";
      }

      match /checkoutSessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      match /statistics/{statisticId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /deletedPrograms/{itemId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /trash/{itemId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /customExercises/{exerciseId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /aiCopilotHistory/{eventId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /aiHistory/{eventId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /appState/{stateId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /imports/{importId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /records/{recordId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /workouts/{workoutId} {
        allow read, create, update, delete: if isOwner(userId);

        match /days/{dayId} {
          allow read, create, update, delete: if isOwner(userId);
        }
      }

      match /history/{historyId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /measurements/{measurementId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    // Medlemskab og AI-grænser er klientdata i demoen. Root-adminfelter
    // beskyttes ovenfor; produktionssikker adgangskontrol bør senere flyttes
    // til backend/Cloud Functions eller custom claims.

    match /appConfig/{configId} {
      allow read: if configId == "pricing";
      allow create, update, delete: if false;
    }

    // F\u00e6lles animationsbibliotek. Alle loggede brugere kan afspille den
    // aktive version; kun den permanente administrator kan oprette,
    // versionere og godkende indhold.
    match /exerciseAnimations/{exerciseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isPermanentAdminEmail();

      match /versions/{versionId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn() && isPermanentAdminEmail();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

